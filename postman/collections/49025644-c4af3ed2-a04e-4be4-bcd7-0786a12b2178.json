							"script": {
								"id": "c9aefb7e-a209-4f02-b2d8-989d4059d0f5",
								"exec": [
									"// Enhanced debug-friendly tests for Customers - Register",
									"",
									"// Always capture metadata for debugging",
									"pm.test('Capture debug metadata', function () {",
									"  pm.expect(true).to.be.true; // placeholder to always run",
									"  pm.environment.set('last_request_url', pm.request.url.toString());",
									"  pm.environment.set('last_request_method', pm.request.method);",
									"  pm.environment.set('last_request_body', pm.request.body ? pm.request.body.raw : '');",
									"  pm.environment.set('last_response_status', String(pm.response.code));",
									"  pm.environment.set('last_response_body', pm.response.text());",
									"});",
									"",
									"// Fail if status is not 201",
									"pm.test('Status is 201 Created', function () {",
									"  pm.expect(pm.response.code, 'Expected 201 Created').to.equal(201);",
									"});",
									"",
									"// If server error, surface hint about DB migrations",
									"if (pm.response.code >= 500) {",
									"  pm.test('Server error - likely DB/migration issue', function () {",
									"    const body = pm.response.text();",
									"    pm.expect.fail('Server returned ' + pm.response.code + ' — inspect server logs. Common cause: missing DB table/migration. Body: ' + body.substring(0, 1000));",
									"  });",
									"}",
									"",
									"// Validate minimal JSON shape on success",
									"if (pm.response.code === 201 && pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
									"  const json = pm.response.json();",
									"  pm.test('Response contains id (number or string)', function () {",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(['number','string']).to.include(typeof json.id);",
									"  });",
									"  pm.test('Response echoes email matching request body', function () {",
									"    try {",
									"      const req = JSON.parse(pm.environment.get('last_request_body') || '{}');",
									"      pm.expect(json.email, 'email should match request').to.eql(req.email);",
									"    } catch (e) {",
									"      pm.expect.fail('Could not parse saved request body for comparison');",
									"    }",
									"  });",
									"}",
									"",
									"// Optional: surface sqlite hint if present in response",
									"(function(){",
									"  const text = pm.response.text().toLowerCase();",
									"  if (text.includes('sqlite') && text.includes('no such table')) {",
									"    pm.test('Detected SQLite missing table error', function(){",
									"      pm.expect.fail('Backend indicates SQLite schema missing: \"no such table\". Ensure migrations ran and the table exists.');",
									"    });",
									"  }",
									"})();"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
