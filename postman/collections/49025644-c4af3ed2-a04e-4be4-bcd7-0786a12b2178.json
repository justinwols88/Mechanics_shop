				{
					"name": "Create Inventory Item",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"id": "d13dfab5-821d-4d14-afcf-f3fda4320151",
								"exec": [
									"// Pre-request: inject mechanic_id from JWT into JSON body",
									"(function () {",
									"  const token = pm.environment.get('mechanicToken');",
									"  if (!token) {",
									"    pm.console.warn('mechanicToken is not set in the active environment. Skipping mechanic_id injection.');",
									"    return;",
									"  }",
									"",
									"  function base64UrlDecode(input) {",
									"    try {",
									"      // Replace URL-safe chars and add padding",
									"      let base64 = input.replace(/-/g, '+').replace(/_/g, '/');",
									"      const pad = base64.length % 4;",
									"      if (pad) base64 += '='.repeat(4 - pad);",
									"      // atob works on ASCII; decode then percent-decode to handle UTF-8",
									"      const binary = atob(base64);",
									"      let str = '';",
									"      for (let i = 0; i < binary.length; i++) {",
									"        str += '%' + ('00' + binary.charCodeAt(i).toString(16)).slice(-2);",
									"      }",
									"      return decodeURIComponent(str);",
									"    } catch (e) {",
									"      pm.console.error('Failed to base64url decode JWT payload:', e);",
									"      return null;",
									"    }",
									"  }",
									"",
									"  function parseJwtPayload(jwt) {",
									"    try {",
									"      const parts = jwt.split('.');",
									"      if (parts.length < 2) {",
									"        pm.console.error('Invalid JWT format: expected 3 parts');",
									"        return null;",
									"      }",
									"      const decoded = base64UrlDecode(parts[1]);",
									"      if (!decoded) return null;",
									"      return JSON.parse(decoded);",
									"    } catch (e) {",
									"      pm.console.error('Failed to parse JWT payload JSON:', e);",
									"      return null;",
									"    }",
									"  }",
									"",
									"  const payload = parseJwtPayload(token);",
									"  if (!payload) {",
									"    pm.console.warn('Could not parse JWT payload; skipping mechanic_id injection.');",
									"    return;",
									"  }",
									"",
									"  let mechanicId = payload.mechanic_id;",
									"  if (mechanicId === undefined || mechanicId === null || mechanicId === '') {",
									"    mechanicId = payload.mechanicId;",
									"  }",
									"  if (mechanicId === undefined || mechanicId === null || mechanicId === '') {",
									"    mechanicId = payload.sub;",
									"  }",
									"",
									"  if (mechanicId === undefined || mechanicId === null || mechanicId === '') {",
									"    pm.console.warn('No mechanic_id/mechanicId/sub found in JWT payload; skipping injection.');",
									"    return;",
									"  }",
									"",
									"  // Coerce to integer if numeric",
									"  if (typeof mechanicId === 'string' && /^\\d+$/.test(mechanicId)) {",
									"    mechanicId = parseInt(mechanicId, 10);",
									"  }",
									"",
									"  // Save to environment for reuse",
									"  try {",
									"    pm.environment.set('mechanicId', mechanicId);",
									"  } catch (e) {",
									"    pm.console.error('Failed to set environment variable mechanicId:', e);",
									"  }",
									"",
									"  // Read and update the current raw JSON body",
									"  try {",
									"    const mode = pm.request.body ? pm.request.body.mode : null;",
									"    if (mode !== 'raw') {",
									"      pm.console.warn('Request body is not raw; current mode:', mode, '. Skipping mechanic_id injection.');",
									"      return;",
									"    }",
									"",
									"    const lang = pm.request.body.options && pm.request.body.options.raw && pm.request.body.options.raw.language;",
									"    const isJson = (lang === 'json') || (function () { try { JSON.parse(pm.request.body.raw); return true; } catch (_) { return false; } })();",
									"    if (!isJson) {",
									"      pm.console.warn('Request body raw is not valid JSON; skipping mechanic_id injection.');",
									"      return;",
									"    }",
									"",
									"    let bodyObj = {};",
									"    try {",
									"      bodyObj = pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
									"    } catch (e) {",
									"      pm.console.error('Failed to parse request JSON body; skipping mechanic_id injection.', e);",
									"      return;",
									"    }",
									"",
									"    bodyObj.mechanic_id = mechanicId;",
									"",
									"    pm.request.body.update(JSON.stringify(bodyObj));",
									"    pm.console.info('Injected mechanic_id into request body from JWT payload.');",
									"  } catch (e) {",
									"    pm.console.error('Unexpected error while injecting mechanic_id:', e);",
									"  }",
									"})();"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"id": "afc01a35-9a31-4991-abe7-20ad30fa1cfd",
