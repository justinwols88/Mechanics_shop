			"name": "Authentication",
			"item": [
				{
					"name": "Customer Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Customers - Login tests with robust handling and safe token persistence",
									"",
									"// Assert status is 200 OK or 401 Unauthorized with clear message",
									"pm.test('Status is 200 OK or 401 Unauthorized', function () {",
									"  pm.expect(pm.response.code, 'Expected 200 for success or 401 for invalid credentials').to.be.oneOf([200, 401]);",
									"});",
									"",
									"// Capture metadata for debugging",
									"pm.test('Capture debug metadata', function () {",
									"  pm.expect(true).to.be.true;",
									"  pm.environment.set('last_request_url', pm.request.url.toString());",
									"  pm.environment.set('last_request_method', pm.request.method);",
									"  pm.environment.set('last_request_body', pm.request.body ? pm.request.body.raw : '');",
									"  pm.environment.set('last_response_status', String(pm.response.code));",
									"  pm.environment.set('last_response_body', pm.response.text());",
									"});",
									"",
									"let json = null;",
									"try {",
									"  if (pm.response.headers.has('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
									"    json = pm.response.json();",
									"  }",
									"  pm.test('Response is JSON when Content-Type is application/json', function () {",
									"    if (pm.response.headers.has('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
									"      pm.expect(json).to.be.an('object');",
									"    } else {",
									"      pm.expect(true, 'Non-JSON response allowed but not expected').to.be.true;",
									"    }",
									"  });",
									"} catch (e) {",
									"  pm.test('Response JSON parseable', function () {",
									"    pm.expect.fail('Response is not valid JSON: ' + e.message);",
									"  });",
									"}",
									"",
									"if (pm.response.code === 200) {",
									"  pm.test('Success body includes token (string)', function () {",
									"    pm.expect(json, 'JSON body expected on success').to.be.an('object');",
									"    pm.expect(json).to.have.property('token');",
									"    pm.expect(json.token).to.be.a('string').and.not.empty;",
									"  });",
									"  // Save token only when present",
									"  if (json && typeof json.token === 'string' && json.token.length > 0) {",
									"    pm.collectionVariables.set('customerToken', json.token);",
									"    pm.environment.set('jwt', json.token);",
									"  }",
									"  // Optional: echo email if present",
									"  pm.test('If email present, it matches the request', function () {",
									"    if (json && json.email) {",
									"      const req = JSON.parse(pm.environment.get('last_request_body') || '{}');",
									"      pm.expect(json.email).to.equal(req.email);",
									"    } else {",
									"      pm.expect(true).to.be.true;",
									"    }",
									"  });",
									"} else if (pm.response.code === 401) {",
									"  // Ensure we do NOT persist token on failure",
									"  pm.collectionVariables.unset('customerToken');",
									"  // Do not override env jwt on failure",
									"  pm.test('Failure body contains helpful message', function () {",
									"    if (json && json.message) {",
									"      pm.expect(json.message).to.be.a('string');",
									"    } else {",
									"      pm.expect(true, 'No message field present').to.be.true;",
									"    }",
									"  });",
									"}",
									""
								]
							}
						}
					],
